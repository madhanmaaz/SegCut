{
    "manifest_version": 3,

    "name": "SegCut",
    "version": "1.0",
    "description": "Mark and cut precise video segments from any website.",

    "permissions": ["tabs", "storage", "webRequest"],
    "host_permissions": ["<all_urls>"],

    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },

    "web_accessible_resources": [
        {
            "resources": ["images/*"],
            "matches": ["<all_urls>"]
        }
    ],

    "action": {},

    "background": {
        "service_worker": "background.js"
    },

    "content_scripts": [
        {
            "all_frames": true,
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "css": ["content.css"]
        }
    ]
}
